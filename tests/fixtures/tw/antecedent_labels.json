      {"id": "walker_bug.paren_overgreedy", "description": "Walker captures trailing character (particle/verb) into the parenthesized numeral group, e.g., 第一銜接部銜接(222) instead of 第一銜接部(222)"},
      {"id": "walker_bug.quantifier_morpheme_collision", "description": "Walker parses 一個 as quantifier + noun start and eats the first character of a compound noun, e.g., 一個人化特徵 parsed as 一個 + 人化特徵 instead of 一 + 個人化特徵"},
      {"id": "walker_bug.regex_noun_class_narrow", "description": "Walker regex noun class fails on a non-CJK char after ordinal and truncates capture to bare 第一/第二"},
      {"id": "legit_drafting_error", "description": "Real drafting error in the source patent — walker is correctly flagging. MUST preserve (protect: true). The round-5 該使用者介面 canonical example lives here."},
      {"id": "propagation_gap", "description": "Term is cleanly introduced in a parent claim but the ancestor-chain walker fails to reach it (cross-category method→system, multi-parent BFS gap, etc.). Phase 9 territory."},
      {"id": "semantic_disjunction_deferred", "description": "全世界/地域-class idiomatic disjunction captures. Deferred to Phase 9 per CLAUDE.md known limitations."},
      {"id": "ambig", "description": "Cannot be categorized from the excerpt alone. Requires reading the full claim text to disambiguate. Christopher will eyeball these."}
